# Use the package owner / admin deploy key for upgrades. In the local `lendpay-4`
# stack this is `BridgeExecutor`, which resolves to `0x5972...`.
# Optional override. By default the scripts derive the module address from
# `minitiad keys parse $(minitiad keys show $ROLLUP_KEY_NAME --address)`.
LENDPAY_PACKAGE_ADDRESS=0x5972A1C7118A8977852DC3307621535D5C1CDA63
TREASURY_ADMIN_ADDRESS=0x5972A1C7118A8977852DC3307621535D5C1CDA63
